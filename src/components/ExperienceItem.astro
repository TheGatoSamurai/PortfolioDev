---
export interface Props {
    title_es: string
    title_en: string
    description_es: string
    description_en: string
    link?: string
    date: string
}

const {
    title_es,
    title_en,
    description_es,
    description_en,
    link,
    date
} = Astro.props;
---

<div class="absolute w-4 h-4 bg-yellow-400 rounded-full mt-1.5 -start-2.5 border-2 border-black shadow-[0_0_10px_rgba(250,204,21,0.6)]"></div>

<div class="p-5 border border-white/10 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors duration-300 shadow-lg">
    
    <time class="mb-2 text-sm font-mono leading-none text-yellow-200/90 block">{date}</time>
    
    <h3 class="text-xl font-bold text-white mt-2">
        <span data-lang="es">{title_es}</span>
        <span data-lang="en" class="hidden">{title_en}</span>
    </h3>

    <p class="mb-4 text-base font-light text-gray-300 text-pretty mt-3 leading-relaxed">
        <span data-lang="es">{description_es}</span>
        <span data-lang="en" class="hidden">{description_en}</span>
    </p>

    {
        link && (
            <a href={link}
               target="_blank"
               rel="noopener noreferrer"
               class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:scale-105 hover:border-yellow-400/50 transition-all duration-300 focus:z-10 focus:outline-none group">
                
                <span data-lang="es">Saber más</span>
                <span data-lang="en" class="hidden">Learn more</span>
                
                <svg class="w-3 h-3 ms-2 rtl:rotate-180 group-hover:translate-x-1 transition-transform" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
                </svg>
            </a>
        )
    }
</div>

