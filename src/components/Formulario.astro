---
// Configuración de contacto
const phoneNumber = "56931089509"; 
const contactEmail = "thegatosamurai@gmail.com";
const displayPhone = "+56 9 3108 9509"; 

// 1. Definimos DOS mensajes (Español e Inglés)
const rawMessageEs = "Hola Gerald, vi tu perfil y me gustaría conversar sobre una oportunidad laboral. 🤝";
const rawMessageEn = "Hi Gerald, I saw your profile and I'd like to discuss a job opportunity. 🤝";

// 2. Creamos DOS links
const whatsappLinkEs = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(rawMessageEs)}`;
const whatsappLinkEn = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(rawMessageEn)}`;
---
<section id="contacto" class="relative overflow-hidden">
    
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-px bg-gradient-to-r from-transparent via-yellow-400/50 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-yellow-400/5 rounded-full blur-[120px] pointer-events-none -z-10"></div>

    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-24 items-center relative z-10 py-16 lg:py-24">
        
        <div class="space-y-8">
            <div>
                <span class="text-yellow-400 font-bold tracking-widest uppercase text-base mb-2 block">
                    <span data-lang="es">Contacto</span>
                    <span data-lang="en" class="hidden">Contact</span>
                </span>
                <h2 class="text-5xl md:text-6xl font-black text-white leading-tight">
                    <span data-lang="es">¿Buscas talento <br /> <span class="text-yellow-400">Comprometido?</span></span>
                    <span data-lang="en" class="hidden">Looking for <br /> <span class="text-yellow-400">Committed Talent?</span></span>
                </h2>
            </div>
            
            <p class="text-gray-300 text-xl leading-relaxed font-light">
                <span data-lang="es">
                    Estoy disponible para integrarme a equipos de desarrollo que valoren el código limpio, la seguridad y la innovación. Si buscas un ingeniero proactivo listo para aportar valor desde el día uno, <strong class="text-white font-semibold">hablemos.</strong>
                </span>
                <span data-lang="en" class="hidden">
                    I am available to join development teams that value clean code, security, and innovation. If you are looking for a proactive engineer ready to add value from day one, <strong class="text-white font-semibold">let's talk.</strong>
                </span>
            </p>

            <div class="space-y-6 pt-4">
                <div class="flex items-center gap-5 group">
                    <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-yellow-400 group-hover:bg-yellow-400 group-hover:text-black transition-all duration-300 shadow-lg">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <h4 class="text-gray-400 text-sm font-medium uppercase tracking-wider">
                            <span data-lang="es">Escríbeme un correo</span>
                            <span data-lang="en" class="hidden">Email me</span>
                        </h4>
                        <a href={`mailto:${contactEmail}`} class="text-xl md:text-2xl text-white font-bold hover:text-yellow-400 transition-colors">{contactEmail}</a>
                    </div>
                </div>

                <div class="flex items-center gap-5 group">
                    <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-yellow-400 group-hover:bg-yellow-400 group-hover:text-black transition-all duration-300 shadow-lg">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <h4 class="text-gray-400 text-sm font-medium uppercase tracking-wider">
                            <span data-lang="es">Hablemos por WhatsApp</span>
                            <span data-lang="en" class="hidden">Chat on WhatsApp</span>
                        </h4>
                        
                        <a href={whatsappLinkEs} target="_blank" data-lang="es" class="text-xl md:text-2xl text-white font-bold hover:text-yellow-400 transition-colors">
                            {displayPhone}
                        </a>
                        
                        <a href={whatsappLinkEn} target="_blank" data-lang="en" class="hidden text-xl md:text-2xl text-white font-bold hover:text-yellow-400 transition-colors">
                            {displayPhone}
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white/5 border border-white/5 rounded-3xl p-8 md:p-10 shadow-2xl backdrop-blur-sm"> 
            <form id="contact-form" class="w-full space-y-6">
                
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="name" class="text-sm font-medium text-gray-400 ml-1">
                            <span data-lang="es">Tu Nombre</span>
                            <span data-lang="en" class="hidden">Your Name</span>
                        </label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 start-0 flex items-center ps-4 pointer-events-none text-gray-500 group-focus-within:text-yellow-400 transition-colors">
                                <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            </div>
                            <input type="text" name="name" id="name" required 
                                class="bg-black/40 border border-white/10 text-white text-base rounded-xl focus:ring-2 focus:ring-yellow-400 focus:border-transparent block w-full ps-12 p-4 transition-all outline-none placeholder-gray-600" 
                                placeholder="Ej: Juan Pérez"
                                data-placeholder-es="Ej: Juan Pérez"
                                data-placeholder-en="Ex: John Doe">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label for="email" class="text-sm font-medium text-gray-400 ml-1">
                            <span data-lang="es">Tu Email</span>
                            <span data-lang="en" class="hidden">Your Email</span>
                        </label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 start-0 flex items-center ps-4 pointer-events-none text-gray-500 group-focus-within:text-yellow-400 transition-colors">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                            </div>
                            <input type="email" name="email" id="email" required 
                                class="bg-black/40 border border-white/10 text-white text-base rounded-xl focus:ring-2 focus:ring-yellow-400 focus:border-transparent block w-full ps-12 p-4 transition-all outline-none placeholder-gray-600" 
                                placeholder="juan@empresa.com"
                                data-placeholder-es="juan@empresa.com"
                                data-placeholder-en="john@company.com">
                        </div>
                    </div>
                </div>

                <input type="text" name="fax_number" id="fax_number" class="hidden" autocomplete="off" tabindex="-1">

                <div class="space-y-2">
                    <label for="subject" class="text-sm font-medium text-gray-400 ml-1">
                        <span data-lang="es">Asunto</span>
                        <span data-lang="en" class="hidden">Subject</span>
                    </label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 start-0 flex items-center ps-4 pointer-events-none text-gray-500 group-focus-within:text-yellow-400 transition-colors">
                           <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        </div>
                        <input type="text" name="subject" id="subject" required 
                            class="bg-black/40 border border-white/10 text-white text-base rounded-xl focus:ring-2 focus:ring-yellow-400 focus:border-transparent block w-full ps-12 p-4 transition-all outline-none placeholder-gray-600" 
                            placeholder="Ej: Oportunidad Laboral"
                            data-placeholder-es="Ej: Oportunidad Laboral"
                            data-placeholder-en="Ex: Job Opportunity">
                    </div>
                </div>

                <div class="space-y-2">
                    <label for="message" class="text-sm font-medium text-gray-400 ml-1">
                        <span data-lang="es">Mensaje</span>
                        <span data-lang="en" class="hidden">Message</span>
                    </label>
                    <div class="relative group">
                        <div class="absolute top-4 left-0 flex items-center ps-4 pointer-events-none text-gray-500 group-focus-within:text-yellow-400 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                        </div>
                        <textarea name="message" id="message" rows="5" required 
                            class="bg-black/40 border border-white/10 text-white text-base rounded-xl focus:ring-2 focus:ring-yellow-400 focus:border-transparent block w-full ps-12 p-4 transition-all outline-none placeholder-gray-600 resize-none" 
                            placeholder="Hola Gerald, estamos buscando..."
                            data-placeholder-es="Hola Gerald, estamos buscando..."
                            data-placeholder-en="Hi Gerald, we are looking for..."></textarea>
                    </div>
                </div>

                <div id="form-status" class="hidden p-4 rounded-xl text-base text-center font-medium"></div>
                
                <button type="submit" id="submit-btn" class="cursor-pointer w-full py-4 px-6 rounded-xl bg-yellow-500 text-black font-extrabold text-lg hover:bg-yellow-400 hover:scale-[1.02] hover:shadow-[0_0_20px_rgba(234,179,8,0.4)] transition-all transform active:scale-95 flex justify-center items-center gap-3">
                    <span data-lang="es">Enviar Mensaje</span>
                    <span data-lang="en" class="hidden">Send Message</span>
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </form>
        </div>
    </div>
</section>

<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

<script is:inline>
    // 1. EmailJS Init
    const PUBLIC_KEY = 'tK8UViD9d3Md7C_7T'; 
    const SERVICE_ID = 'service_cs98tmm';     
    const TEMPLATE_ID = 'template_whfdywb';   

    (function(){
        try { emailjs.init({ publicKey: PUBLIC_KEY }); } catch(e) {}
    })();

    // 2. Manejo de envío
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('submit-btn');
    const statusDiv = document.getElementById('form-status');

    if(form) {
        form.addEventListener('submit', function(event) {
            event.preventDefault();
            const honeypot = document.getElementById('fax_number').value;
            if (honeypot) return; 

            const originalBtnHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = `<span class="animate-spin inline-block w-5 h-5 border-2 border-black border-t-transparent rounded-full mr-2"></span>`;
            statusDiv.classList.add('hidden');

            emailjs.sendForm(SERVICE_ID, TEMPLATE_ID, this)
                .then(() => {
                    btn.innerHTML = `✅`;
                    statusDiv.innerHTML = `<span data-lang="es">¡Mensaje Enviado!</span><span data-lang="en" class="hidden">Message Sent!</span>`;
                    statusDiv.className = "p-4 rounded-xl text-base text-center font-medium bg-green-500/10 text-green-400 border border-green-500/20 block mt-4";
                    form.reset();
                    updateFormLanguage(); 
                    
                    setTimeout(() => { 
                        btn.disabled = false; 
                        btn.innerHTML = originalBtnHtml; 
                        statusDiv.classList.add('hidden');
                    }, 5000);
                }, (error) => {
                    console.error('FAILED...', error);
                    btn.disabled = false;
                    btn.innerHTML = "Error";
                    statusDiv.textContent = "Error. Please email me directly.";
                    statusDiv.className = "p-4 rounded-xl text-base text-center font-medium bg-red-500/10 text-red-400 border border-red-500/20 block mt-4";
                });
        });
    }

    // 3. Script para cambiar Placeholders y Textos al cambiar idioma
    function updateFormLanguage() {
        const root = document.documentElement;
        const lang = root.dataset.lang || 'es';

        // A) Cambiar Placeholders
        const inputs = document.querySelectorAll('[data-placeholder-es]');
        inputs.forEach(input => {
            if(lang === 'es') {
                input.placeholder = input.getAttribute('data-placeholder-es');
            } else {
                input.placeholder = input.getAttribute('data-placeholder-en');
            }
        });

        // B) Cambiar Visibilidad de Textos (Spans)
        document.querySelectorAll('#contact-form [data-lang], #contacto [data-lang]').forEach(el => {
            if(el.getAttribute('data-lang') === lang) {
                el.classList.remove('hidden');
            } else {
                el.classList.add('hidden');
            }
        });
    }

    // Observador
    const observer = new MutationObserver(() => updateFormLanguage());
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });
    
    // Inicio
    document.addEventListener('DOMContentLoaded', updateFormLanguage);
</script>