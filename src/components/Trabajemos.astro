---
import Mail from '../components/icon/Mail.astro';
import LinkeindIcon from '../components/icon/Linkedin.astro'; // Usamos el icono que ya tienes
---

<section class="relative w-full max-w-5xl mx-auto px-4">
    
    <div class="absolute inset-0 bg-gradient-to-r from-yellow-400 via-purple-600 to-blue-600 rounded-[2.5rem] blur-xl opacity-20 transform scale-[0.98]"></div>

    <div class="relative bg-black/80 backdrop-blur-xl border border-white/10 rounded-[2rem] p-8 md:p-16 text-center overflow-hidden group">
        
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-gradient-to-b from-white/5 to-transparent pointer-events-none"></div>

        <h2 class="relative z-10 text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 tracking-tight">
            <span data-lang="es">¿Tienes un proyecto en mente?</span>
            <span data-lang="en" class="hidden">Have a project in mind?</span>
        </h2>

        <p class="relative z-10 text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-10 text-pretty">
            <span data-lang="es">
                Transformemos tus ideas en realidad. Estoy disponible para nuevos desafíos en desarrollo <strong class="text-yellow-300">Web</strong>, <strong class="text-blue-400">Apps</strong> y <strong class="text-purple-400">Ciberseguridad</strong>.
            </span>
            <span data-lang="en" class="hidden">
                Let's turn your ideas into reality. I'm available for new challenges in <strong class="text-yellow-300">Web</strong>, <strong class="text-blue-400">Apps</strong>, and <strong class="text-purple-400">Cybersecurity</strong>.
            </span>
        </p>

        <div class="relative z-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
            
            <a
                href="mailto:thegatosamurai@gmail.com"
                class="group/btn relative inline-flex items-center justify-center gap-3 px-8 py-4 font-bold text-white transition-all duration-300 bg-white/5 border border-white/10 rounded-full hover:bg-yellow-400 hover:text-black hover:scale-105 hover:border-yellow-400 shadow-lg"
            >
                <Mail class="size-6 transition-transform group-hover/btn:-translate-y-0.5 group-hover/btn:scale-110" />
                <span data-lang="es">Envíame un correo</span>
                <span data-lang="en" class="hidden">Send me an email</span>
            </a>

            <a
                href="https://www.linkedin.com/in/thegatosamurai/"
                target="_blank"
                rel="noopener noreferrer"
                class="group/btn relative inline-flex items-center justify-center gap-3 px-8 py-4 font-bold text-white transition-all duration-300 bg-blue-600/10 border border-blue-500/30 rounded-full hover:bg-blue-600 hover:text-white hover:scale-105 hover:border-blue-500 shadow-lg hover:shadow-blue-600/20"
            >
                <svg class="size-6 fill-current" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <span>LinkedIn</span>
            </a>

        </div>

    </div>
</section>