<div class="typing-container">
    <span class="static-text">Hey,</span>
    <span class="dynamic-text">
        <span data-lang="es" class="typing-word"></span>
        <span data-lang="en" class="typing-word hidden"></span>
        <span class="cursor">|</span>
    </span>
</div>

<style>
    .typing-container {
        display: inline-flex;
        align-items: center;
        gap: 10px; 
    }

    .static-text {
        color: white;
        font-weight: bold; /* Le agregué bold para que se vea mejor */
    }

    .dynamic-text {
        display: inline-flex;
        align-items: center;
        position: relative;
        color: #facc15; 
        font-weight: bold;
    }

    .cursor {
        display: inline-block;
        color: #facc15;
        font-weight: 100;
        animation: blink 1s step-end infinite;
        margin-left: 2px;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }
</style>

<script>
    const words = {
        es: ["Soy Gerald", "Full Stack Dev", "Ethical Hacker", "Ingeniero"],
        en: ["I'm Gerald", "Full Stack Dev", "Ethical Hacker", "Engineer"]
    };

    const typingSpeed = 100;
    const erasingSpeed = 50;
    const delayBetweenWords = 2000;

    const elements = document.querySelectorAll('.typing-word');

    elements.forEach(element => {
        let wordIndex = 0;
        let charIndex = 0;
        let isDeleting = false;

        const typeEffect = () => {
            // 1. OBTENEMOS EL IDIOMA (Lógica JS compatible)
            const attr = document.documentElement.dataset.lang;
            
            // 2. FORZAMOS QUE SEA 'es' O 'en'
            // Si es 'en', usa 'en'. Si es null, undefined o 'es', usa 'es'.
            // Esto evita el error de "índice string genérico".
            const currentLang = attr === 'en' ? 'en' : 'es';
            
            if (!element) return;

            // Comparamos usando la variable segura
            if (element.getAttribute('data-lang') !== currentLang) {
                setTimeout(typeEffect, 500); 
                return;
            }

            // Aquí ya no dará error porque currentLang solo puede ser "es" o "en"
            const currentWord = words[currentLang][wordIndex];

            if (isDeleting) {
                charIndex--;
                element.textContent = currentWord.substring(0, charIndex);
            } else {
                charIndex++;
                element.textContent = currentWord.substring(0, charIndex);
            }

            if (!isDeleting && charIndex === currentWord.length) {
                isDeleting = true;
                setTimeout(typeEffect, delayBetweenWords);
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                wordIndex = (wordIndex + 1) % words[currentLang].length;
                setTimeout(typeEffect, 500);
            } else {
                const speed = isDeleting ? erasingSpeed : typingSpeed;
                setTimeout(typeEffect, speed);
            }
        };

        typeEffect();
    });
</script>