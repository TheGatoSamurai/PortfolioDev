---
// Importación de Iconos
import HTML from './icon/skill/SkillHtml.astro';
import CSS from './icon/skill/SkillCss.astro';
import JavaScript from './icon/skill/SkillJs.astro';
import Bootstrap from './icon/skill/SkillBootstrap.astro';
import Typescript from './icon/skill/SkillTypescript.astro';
import Angular from './icon/skill/SkillAngular.astro';
import Ionic from './icon/skill/SkillIonic.astro';
import IconAstro from './icon/skill/SkillAstro.astro';
import IconTailwind from './icon/skill/SkillTailwind.astro';
import Shopify from './icon/skill/SkillShopify.astro';
import Flutter from './icon/skill/SkillFlutter.astro';
import Firebase from './icon/skill/SkillFirebase.astro';
import GitHub from './icon/skill/SkillGithub.astro';
import GitOnly from './icon/skill/GitOnly.astro';
import Vscode from './icon/skill/Vscode.astro';
import Npm from './icon/skill/Npm.astro';
import React from './icon/skill/SkillReact.astro';
import Mysql from './icon/skill/Mysql.astro';
import Python from './icon/skill/SkillPython.astro';
import Sass from './icon/Sass.astro';
import PlSql from './icon/skill/PlSql.astro';
import Bun from './icon/skill/Bun.astro';
import Godot from './icon/skill/Godot.astro';
import Csharp from './icon/skill/Csharp.astro';
import Canva from './icon/skill/Canva.astro';
import AndroidStudio from './icon/skill/AndroidStudio.astro';
import Java from './icon/skill/Java.astro';
import Linux from './icon/skill/Linux.astro';
import Confluence from './icon/skill/Confluence.astro';
import MongoDb from './icon/skill/MongoDb.astro';
import Moodle from './icon/skill/Moodle.astro';
import Php from './icon/skill/Php.astro';
import WooComerce from './icon/skill/WooComerce.astro';
import Wordpress from './icon/skill/WordPress.astro';
import Notion from './icon/skill/Notion.astro';

// Estructura de Datos (Para no repetir código HTML)
const SKILLS_DATA = [
    {
        title_es: "Frontend",
        title_en: "Frontend",
        iconClass: "text-blue-400", // Color del icono del título (opcional)
        skills: [
            { name: "Astro", icon: IconAstro },
            { name: "HTML", icon: HTML },
            { name: "CSS", icon: CSS },
            { name: "JavaScript", icon: JavaScript },
            { name: "Tailwind", icon: IconTailwind },
            { name: "Sass", icon: Sass },
            { name: "TypeScript", icon: Typescript },
            { name: "Flutter", icon: Flutter },
            { name: "React", icon: React },
        ]
    },
    {
        title_es: "Backend",
        title_en: "Backend",
        iconClass: "text-green-400",
        skills: [
            { name: "Angular", icon: Angular },
            { name: "Ionic", icon: Ionic },
            { name: "Firebase", icon: Firebase },
            { name: "Bootstrap", icon: Bootstrap },
            { name: "MySQL", icon: Mysql },
            { name: "Python", icon: Python },
            { name: "PL/SQL", icon: PlSql },
            { name: "Java", icon: Java },
            { name: "MongoDB", icon: MongoDb },
        ]
    },
    {
        title_es: "Aprendiendo",
        title_en: "Learning",
        iconClass: "text-purple-400",
        skills: [
            { name: "C#", icon: Csharp },
            { name: "Godot", icon: Godot },
            { name: "PHP", icon: Php },
            { name: "WordPress", icon: Wordpress },
            { name: "WooCommerce", icon: WooComerce },
            { name: "Moodle", icon: Moodle },
        ]
    },
    {
        title_es: "Herramientas",
        title_en: "Tools",
        iconClass: "text-yellow-400",
        skills: [
            { name: "Git", icon: GitOnly },
            { name: "VS Code", icon: Vscode },
            { name: "Shopify", icon: Shopify },
            { name: "GitHub", icon: GitHub },
            { name: "NPM", icon: Npm },
            { name: "Bun", icon: Bun },
            { name: "Canva", icon: Canva },
            { name: "Android Studio", icon: AndroidStudio },
            { name: "Linux", icon: Linux },
            { name: "Confluence", icon: Confluence },
            { name: "Notion", icon: Notion },
        ]
    }
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
    
    {SKILLS_DATA.map((group) => (
        <article class="bg-white/5 border border-white/10 rounded-[2rem] p-6 md:p-8 hover:bg-white/[0.07] hover:border-white/20 transition-all duration-300 shadow-xl backdrop-blur-sm group/card">
            
            <h3 class="text-xl md:text-2xl font-bold mb-6 flex items-center gap-3 text-white border-b border-white/5 pb-4">
                <span class={`w-2 h-8 rounded-full bg-gradient-to-b from-yellow-400 to-transparent opacity-80`}></span>
                <span data-lang="es">{group.title_es}</span>
                <span data-lang="en" class="hidden">{group.title_en}</span>
            </h3>

            <ul class="grid grid-cols-3 sm:grid-cols-4 gap-4 justify-items-center">
                {group.skills.map((skill) => (
                    <li class="flex flex-col items-center gap-2 group/skill w-full">
                        
                        <div class="relative flex items-center justify-center w-16 h-16 rounded-2xl bg-black/20 border border-white/5 shadow-inner transition-all duration-300 group-hover/skill:scale-110 group-hover/skill:bg-white/10 group-hover/skill:border-yellow-400/30 group-hover/skill:shadow-[0_0_15px_rgba(250,204,21,0.1)]">
                            <skill.icon class="size-8 md:size-9 transition-transform duration-300 group-hover/skill:rotate-3" />
                        </div>
                        
                        <span class="text-xs font-medium text-gray-400 group-hover/skill:text-yellow-200 transition-colors text-center w-full truncate px-1">
                            {skill.name}
                        </span>

                    </li>
                ))}
            </ul>
        </article>
    ))}

</div>