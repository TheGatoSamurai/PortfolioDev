---
export interface Props {
  title_es: string;
  title_en: string;
  description_es: string;
  description_en: string;
  image: string;
  tags: {
    name: string;
    class?: string; // <--- AGREGUÉ EL "?" PARA QUE SEA OPCIONAL
    icon: any;
  }[];
  link?: string;
}

const { title_es, title_en, description_es, description_en, image, tags, link } = Astro.props;
---

<article class="group relative flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-2xl transition-all duration-300 hover:bg-white/10 hover:shadow-purple-900/20 hover:-translate-y-1 h-full">
  
  <a href={link} target="_blank" rel="noopener noreferrer" class="relative overflow-hidden aspect-video block">
      <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors z-10"></div>
      <img 
        class="object-cover object-top w-full h-full transition-transform duration-500 group-hover:scale-105" 
        src={image} 
        alt={`Screenshot del proyecto ${title_es}`} 
        loading="lazy"
      />
  </a>

  <div class="flex flex-col flex-grow p-6">
    
    <h3 class="text-xl font-bold text-yellow-400 mb-2 group-hover:text-yellow-300 transition-colors">
      <a href={link} target="_blank" rel="noopener noreferrer">
        <span data-lang="es">{title_es}</span>
        <span data-lang="en" class="hidden">{title_en}</span>
      </a>
    </h3>

    <p class="text-gray-400 text-sm leading-relaxed mb-6 line-clamp-3 text-pretty">
        <span data-lang="es">{description_es}</span>
        <span data-lang="en" class="hidden">{description_en}</span>
    </p>

    <div class="mt-auto flex flex-col gap-4">
        
        <ul class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <li class="flex items-center gap-1.5 px-3 py-1 text-xs font-medium text-white/90 bg-white/10 rounded-full border border-white/5 hover:bg-white/20 transition-colors cursor-default">
              <tag.icon class="size-3.5" />
              <span>{tag.name}</span>
            </li>
          ))}
        </ul>

        {link && (
            <div class="pt-2">
                <a href={link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-blue-400 hover:text-blue-300 transition-colors group/link">
                    <span data-lang="es">Ver Proyecto</span>
                    <span data-lang="en" class="hidden">View Project</span>
                    <svg class="size-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </a>
            </div>
        )}
    </div>

  </div>
</article>