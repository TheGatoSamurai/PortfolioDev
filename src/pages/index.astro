---
import Layout from '../layouts/Layout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import SectionContainer2 from '../components/SectionContainer2.astro'; 
import Hero from '../components/Hero.astro'; 
import Experience from '../components/Expirience.astro';
import BriefCaseIcon from '../components/icon/BriefCase.astro';
import CodeIcon from '../components/icon/Code.astro';
import Projects from '../components/Projects.astro';
import AboutMe from '../components/AboutMe.astro';
import AmongIcon from '../components/icon/Among.astro';
import ImagenFoto from '../components/Imagen.astro';
import Skills from '../components/Skills.astro';
import SkillsIcon from '../components/icon/SkillsIcon.astro';
import Certificacion from '../components/Certificacion.astro';
import CertificateIcon from '../components/icon/Certificate.astro';
import Formulario from '../components/Formulario.astro';
import Trabajemos from '../components/Trabajemos.astro';
import ContactIcon from '../components/icon/Contact.astro';
---

<Layout 
    title="Gerald Quiñenao - Ingeniero & Full Stack Developer"
    description="Portafolio profesional de Gerald Quiñenao. Especialista en desarrollo web, ciberseguridad y soluciones digitales.">
    
    <main> 
        
        <Hero />

        <SectionContainer id="experiencia" class="py-20 md:py-32">
            <h2 class="text-5xl md:text-6xl font-black text-white mb-12 flex items-center gap-4">
                <BriefCaseIcon class="size-12 md:size-16 text-yellow-400"/>
                <div>
                    <span data-lang="es">Experiencia</span>
                    <span data-lang="en" class="hidden">Experience</span>
                </div>
            </h2>
            <Experience/>
        </SectionContainer>

        <SectionContainer2 id="proyectos" class="py-20 md:py-32">
            <h2 class="text-5xl md:text-6xl font-black text-white mb-16 flex items-center gap-4 px-4 md:px-0">
                <CodeIcon class="size-12 md:size-16 text-blue-500"/>
                <div>
                    <span data-lang="es">Proyectos</span>
                    <span data-lang="en" class="hidden">Projects</span>
                </div>
            </h2>
            <Projects/>
        </SectionContainer2>

        <SectionContainer2 id="sobre-mi" class="py-24 md:py-36">
            <h2 class="text-5xl md:text-6xl font-black text-white mb-16 flex items-center gap-4 px-4 xl:px-0">
                <AmongIcon class="size-12 md:size-16 text-yellow-400"/>
                <div>
                    <span data-lang="es">Sobre mí</span>
                    <span data-lang="en" class="hidden">About me</span>
                </div>
            </h2>
            
            <div class="flex flex-col md:flex-row gap-10 md:gap-16 items-center bg-white/5 border border-white/10 rounded-[2.5rem] p-6 md:p-12 lg:p-16 shadow-2xl backdrop-blur-sm hover:bg-white/[0.07] transition-colors duration-500">
                <div class="w-full md:w-2/5 flex justify-center md:justify-end">
                    <div class="relative">
                        <ImagenFoto /> 
                    </div>
                </div>
                <div class="w-full md:w-3/5">
                    <AboutMe/>
                </div>
            </div>
        </SectionContainer2>

        <SectionContainer2 id="skills" class="py-20 md:py-32">
            <h2 class="text-5xl md:text-6xl font-black text-white mb-16 flex items-center justify-center md:justify-start gap-4">
                <SkillsIcon class="size-12 md:size-16 text-green-400"/>
                <div>
                    <span data-lang="es">Habilidades</span>
                    <span data-lang="en" class="hidden">Skills</span>
                </div>
            </h2>
            <Skills/>
        </SectionContainer2>

        <SectionContainer2 id="certificate" class="py-20 md:py-32">
            <h2 class="text-3xl sm:text-4xl md:text-6xl font-black text-white mb-16 flex items-center gap-4 px-4 md:px-0">
                <CertificateIcon class="w-12 h-12 md:w-16 md:h-16 text-purple-400 shrink-0"/>
                <div>
                    <span data-lang="es">Certificaciones</span>
                    <span data-lang="en" class="hidden">Certificates</span>
                </div>
            </h2>
            <Certificacion />
        </SectionContainer2>
        
        <div class="mt-20 md:mt-32 mb-10">
            <Trabajemos />
        </div>

        <SectionContainer2 class="pt-20 md:pt-32">
            <h2 class="text-3xl sm:text-4xl md:text-6xl font-black text-white mb-16 flex items-center gap-4 px-4 md:px-0">
                <ContactIcon class="w-14 h-14 md:w-16 md:h-16 text-yellow-400"/>
                <div>
                    <span data-lang="es">Contáctame</span>
                    <span data-lang="en" class="hidden">Contact me</span>
                </div>
            </h2>
        </SectionContainer2>
        <div class="pb-20">
            <Formulario />
        </div>
    </main>
</Layout>