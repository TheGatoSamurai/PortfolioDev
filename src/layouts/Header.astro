---
import Among from '../components/icon/Among.astro';
import BriefCase from '../components/icon/BriefCase.astro';
import Certificate from '../components/icon/Certificate.astro';
import Code from '../components/icon/Code.astro';
import Contact from '../components/icon/Contact.astro';
import Home from '../components/icon/Home.astro';
import SkillsIcon from '../components/icon/SkillsIcon.astro';
import Instagram from '../components/icon/Instagram.astro';
import LanguageToggle from '../components/LanguageToggle.astro';

const navItems = [
  { label: "inicio", url: "#top", Icon: Home, title_es: "Inicio", title_en: "Home" },
  { label: "experiencia", url: "#experiencia", Icon: BriefCase, title_es: "Experiencia", title_en: "Experience" },
  { label: "proyectos", url: "#proyectos", Icon: Code, title_es: "Proyectos", title_en: "Projects" },
  { label: "sobre-mi", url: "#sobre-mi", Icon: Among, title_es: "Sobre mí", title_en: "About me" },
  { label: "skills", url: "#skills", Icon: SkillsIcon, title_es: "Skills", title_en: "Skills" },
  { label: "certificaciones", url: "#certificate", Icon: Certificate, title_es: "Certificación", title_en: "Certification" },
  { label: "contacto", url: "#contacto", Icon: Contact, title_es: "Contacto", title_en: "Contact" },
];
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 flex justify-center w-full mt-4 px-2 md:px-6 transition-all duration-500">
    
    <nav id="nav-container" class="flex flex-col md:flex-row w-[95%] max-w-5xl p-2 md:px-4 md:py-2 text-sm md:text-base font-medium rounded-2xl bg-transparent border border-transparent items-center justify-between transition-all duration-300 md:rounded-full">
        
        <div class="flex flex-wrap justify-center md:justify-start items-center gap-1 w-full md:w-auto">
            {
                navItems.map((link) => (
                    <a
                        class="relative block px-2 py-2 md:px-3 transition-all rounded-full hover:bg-white/10 nav-item group"
                        aria-label={link.label}
                        href={link.url}
                    >
                        <span class="hidden md:block transition-colors group-hover:text-yellow-400">
                            <span data-lang="es">{link.title_es}</span>
                            <span data-lang="en" class="hidden">{link.title_en}</span>
                        </span>
                        <span class="block md:hidden transition-colors group-hover:text-yellow-400">
                            <link.Icon class="size-5 sm:size-6" />
                        </span>
                    </a>
                ))
            }
        </div>

        <div class="block md:hidden w-3/4 h-[1px] bg-white/10 my-1 mx-auto opacity-0 transition-opacity" id="mobile-separator"></div>

        <div class="flex items-center justify-center gap-4 w-full md:w-auto pb-1 md:pb-0">
            <div class="hidden md:block h-6 w-[1px] bg-white/20 mx-2"></div>
            
            <a
                href="https://www.instagram.com/thegatosamurai/"
                class="p-1.5 rounded-full hover:bg-white/10 transition-all duration-200 hover:scale-110 hover:text-pink-500 text-white/90"
                aria-label="Instagram"
                target="_blank"
                rel="noopener noreferrer"
            >
                <Instagram class="size-5 sm:size-6 fill-current" />
            </a>
            
            <div class="lang-wrapper p-1 rounded-full hover:bg-white/10 transition-all flex items-center justify-center">
                <LanguageToggle />
            </div>
        </div>
    </nav>
</header>

<script>
    const header = document.getElementById('main-header');
    const navContainer = document.getElementById('nav-container');
    const mobileSeparator = document.getElementById('mobile-separator');
    let lastScrollY = window.scrollY;

    window.addEventListener('scroll', () => {
        const currentScrollY = window.scrollY;

        // Ocultar al bajar
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
            header?.classList.add('-translate-y-[200%]', 'opacity-0');
        } else {
            header?.classList.remove('-translate-y-[200%]', 'opacity-0');
        }

        // Fondo oscuro al hacer scroll
        if (currentScrollY > 20) {
            navContainer?.classList.remove('bg-transparent', 'border-transparent');
            navContainer?.classList.add('bg-black/80', 'backdrop-blur-xl', 'border-white/10', 'shadow-2xl');
            mobileSeparator?.classList.remove('opacity-0');
        } else {
            navContainer?.classList.add('bg-transparent', 'border-transparent');
            navContainer?.classList.remove('bg-black/80', 'backdrop-blur-xl', 'border-white/10', 'shadow-2xl');
             mobileSeparator?.classList.add('opacity-0');
        }

        lastScrollY = currentScrollY;
    });

    // Active Link
    const sections = document.querySelectorAll("section");
    const navItems = document.querySelectorAll("header nav a.nav-item");
    const callback = (entries: any[]) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                navItems.forEach((item) => {
                    if (item.getAttribute("aria-label") == entry.target.id) {
                        item.classList.add("text-yellow-400", "bg-white/10");
                        item.classList.remove("text-white/70");
                    } else {
                        item.classList.remove("text-yellow-400", "bg-white/10");
                        item.classList.add("text-white/70");
                    }
                });
            }
        });
    };
    const observer = new IntersectionObserver(callback, { root: null, rootMargin: "0px", threshold: 0.25 });
    sections.forEach((section) => observer.observe(section));

    // Idiomas
    (function(){
        const root = document.documentElement;
        function applyLang(){
            const lang = root.dataset.lang || 'es';
            document.querySelectorAll('[data-lang]').forEach(el => {
                if(el.getAttribute('data-lang') === lang) {
                    el.classList.remove('hidden');
                } else {
                    el.classList.add('hidden');
                }
            });
        }
        applyLang();
        const obs = new MutationObserver(() => applyLang());
        obs.observe(root, { attributes: true, attributeFilter: ['data-lang'] });
        document.addEventListener('DOMContentLoaded', applyLang);
    })();
</script>

<style is:global>
    .lang-wrapper button, .lang-wrapper select {
        background: transparent !important;
        border: none !important;
        color: rgba(255, 255, 255, 0.9) !important;
        font-weight: 600;
        cursor: pointer;
        padding: 0.2rem 0.5rem;
        font-size: 0.85rem;
    }
    .lang-wrapper option { background-color: #000; color: white; }
</style>