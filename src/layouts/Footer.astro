---
import Instagram from '../components/icon/Instagram.astro';
import GitHub from '../components/icon/GitHub.astro';

// Definimos los enlaces del sitio
const siteLinks = [
    { href: "#top", text_es: "Inicio", text_en: "Home" },
    { href: "#experiencia", text_es: "Experiencia", text_en: "Experience" },
    { href: "#proyectos", text_es: "Proyectos", text_en: "Projects" },
    { href: "#sobre-mi", text_es: "Sobre mí", text_en: "About me" },
    { href: "#skills", text_es: "Skills", text_en: "Skills" },
    { href: "#contacto", text_es: "Contacto", text_en: "Contact" },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative w-full border-t border-white/10 mt-20 pt-12 pb-8 bg-black/60 backdrop-blur-xl">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[1px] bg-gradient-to-r from-transparent via-yellow-400/40 to-transparent"></div>

    <div class="w-full max-w-screen-2xl mx-auto px-6 md:px-12">
        <div class="md:flex md:justify-between md:items-start gap-12">
            
            <div class="mb-10 md:mb-0 text-center md:text-left">
                <a href="#top" class="flex items-center justify-center md:justify-start gap-4 mb-4 group">
                    <img 
                        src="/images/Portafolioblanco250.png" 
                        alt="Logo Gerald" 
                        class="size-12 rounded-full border-2 border-white/10 group-hover:border-yellow-400 transition-colors shadow-lg"
                    />
                    <span class="self-center text-2xl font-black whitespace-nowrap text-white group-hover:text-yellow-400 transition-colors">
                        Gerald Quiñenao
                    </span>
                </a>
                <p class="text-gray-400 text-base max-w-sm mx-auto md:mx-0 leading-relaxed">
                    <span data-lang="es">Ingeniero en Informática & Desarrollador Full Stack. Creando soluciones digitales robustas desde Santiago, Chile. 🇨🇱</span>
                    <span data-lang="en" class="hidden">Computer Engineer & Full Stack Developer. Building robust digital solutions from Santiago, Chile. 🇨🇱</span>
                </p>
            </div>

            <div class="grid grid-cols-2 gap-x-12 gap-y-4 text-center md:text-left mb-10 md:mb-0">
                <div class="space-y-4">
                    <h2 class="text-sm font-bold text-yellow-400 uppercase tracking-widest">
                        <span data-lang="es">Menú</span>
                        <span data-lang="en" class="hidden">Menu</span>
                    </h2>
                    <ul class="text-gray-400 font-medium space-y-3">
                        {siteLinks.slice(0, 3).map(link => (
                            <li>
                                <a href={link.href} class="hover:text-white transition-colors text-base">
                                    <span data-lang="es">{link.text_es}</span>
                                    <span data-lang="en" class="hidden">{link.text_en}</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
                <div class="space-y-4 pt-8 md:pt-0">
                    <h2 class="hidden md:block text-sm font-bold text-transparent uppercase tracking-widest select-none">.</h2> 
                    <ul class="text-gray-400 font-medium space-y-3">
                         {siteLinks.slice(3).map(link => (
                            <li>
                                <a href={link.href} class="hover:text-white transition-colors text-base">
                                    <span data-lang="es">{link.text_es}</span>
                                    <span data-lang="en" class="hidden">{link.text_en}</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>

            <div class="text-center md:text-right">
                <h2 class="mb-6 text-sm font-bold text-yellow-400 uppercase tracking-widest">
                    <span data-lang="es">Conectemos</span>
                    <span data-lang="en" class="hidden">Let's Connect</span>
                </h2>
                <div class="flex justify-center md:justify-end gap-4">
                    <a href="https://github.com/TheGatoSamurai" target="_blank" class="p-2 rounded-full bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white transition-all hover:scale-110 hover:-translate-y-1" aria-label="GitHub">
                        <GitHub class="size-7" />
                    </a>
                    <a href="https://www.instagram.com/thegatosamurai/" target="_blank" class="p-2 rounded-full bg-white/5 hover:bg-white/10 text-gray-400 hover:text-pink-500 transition-all hover:scale-110 hover:-translate-y-1" aria-label="Instagram">
                        <Instagram class="size-7" />
                    </a>
                    <a href="https://www.linkedin.com/in/thegatosamurai/" target="_blank" class="p-2 rounded-full bg-white/5 hover:bg-white/10 text-gray-400 hover:text-blue-500 transition-all hover:scale-110 hover:-translate-y-1" aria-label="LinkedIn">
                        <svg class="size-7" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z" /><path d="M8 11l0 5" /><path d="M8 8l0 .01" /><path d="M12 16l0 -5" /><path d="M16 16v-3a2 2 0 0 0 -4 0" /></svg>
                    </a>
                     <a href="https://x.com/Thegatosamurai" target="_blank" class="p-2 rounded-full bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white transition-all hover:scale-110 hover:-translate-y-1" aria-label="X (Twitter)">
                        <svg class="size-7" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 4l11.733 16h4.267l-11.733 -16z" /><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" /></svg>
                    </a>
                </div>
            </div>
        </div>

        <hr class="my-8 border-white/5" />
        
        <div class="text-center">
            <span class="text-base text-gray-500">
                © {currentYear} <a href="https://www.linkedin.com/in/thegatosamurai/" class="hover:text-yellow-400 font-medium transition-colors">Gerald Quiñenao</a>. 
                <span data-lang="es">Casi todos los derechos reservados.</span>
                <span data-lang="en" class="hidden">All rights reserved.</span>
            </span>
        </div>
    </div>
</footer>